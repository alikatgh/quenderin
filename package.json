{
  "name": "quenderin-poc",
  "description": "An offline autonomous agent control",
  "version": "0.0.1",
  "author": "Quenderin Team",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dashboard": "tsx src/index.ts dashboard",
    "agent": "tsx src/index.ts agent",
    "check": "npm run typecheck && npm run lint",
    "typecheck": "npm run typecheck:src && npm run typecheck:ui",
    "typecheck:src": "tsc --noEmit",
    "typecheck:ui": "cd ui && npx tsc --noEmit",
    "lint": "npm run lint:src && npm run lint:ui",
    "lint:src": "eslint src --ext .ts --max-warnings=0",
    "lint:ui": "eslint ui/src --ext .ts,.tsx --max-warnings=0",
    "build:tsc": "tsc",
    "electron:dev": "npm run build:tsc && electron .",
    "electron:build": "npm run build:tsc && electron-builder --mac"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "^4.0.2",
    "@picovoice/pvrecorder-node": "^1.2.8",
    "@xenova/transformers": "^2.17.2",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.8",
    "hnswlib-node": "^3.0.0",
    "node-llama-cpp": "^3.2.0",
    "open": "^11.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "screenshot-desktop": "^1.15.3",
    "tesseract.js": "^7.0.0",
    "unzipper": "^0.12.3",
    "whisper-node": "^1.1.1",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "robotjs": "^0.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.2",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.18.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
