        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文字大小"
          }
        }
      }
    },
    "The agent needs a loaded model.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エージェントには読み込み済みモデルが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "에이전트에는 로드된 모델이 필요합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Агенту нужна загруженная модель."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体需要已加载的模型。"
          }
        }
      }
    },
    "The ⋯ menu on each model can delete it and free space — the active model is protected.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各モデルの⋯メニューから削除して容量を空けられます — 使用中のモデルは保護されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 모델의 ⋯ 메뉴에서 삭제해 공간을 확보할 수 있습니다 — 활성 모델은 보호됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меню ⋯ у каждой модели позволяет удалить её и освободить место — активная модель защищена."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个模型的 ⋯ 菜单可删除它以释放空间——当前使用的模型受保护。"
          }
        }
      }
    },
    "Their transcripts and per-chat settings are removed from this Mac. This can't be undone.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トランスクリプトとチャットごとの設定がこのMacから削除されます。元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화 내용과 채팅별 설정이 이 Mac에서 삭제됩니다. 되돌릴 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Их история и настройки будут удалены с этого Mac. Это действие необратимо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "它们的记录和各自设置将从这台 Mac 上删除。此操作无法撤销。"
          }
        }
      }
    },
    "Theme": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テーマ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "테마"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тема"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主题"
          }
        }
      }
    },
    "They download one after another and can be deleted any time in Settings → Storage.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルは順番にダウンロードされ、設定 → ストレージからいつでも削除できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델은 차례로 다운로드되며 설정 → 저장 공간에서 언제든 삭제할 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Они загружаются по очереди; удалить можно в любой момент в Настройках → Хранилище."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "它们会依次下载，并可随时在设置 → 存储中删除。"
          }
        }
      }
    },
    "This is the model you’re using now.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在使用中のモデルです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 사용 중인 모델입니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это модель, которую вы используете сейчас."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是你当前使用的模型。"
          }
        }
      }
    },
    "This model needs ~%@ GB — your %@ has %@ GB free.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このモデルには約%1$@ GBが必要です — あなたの%2$@の空きは%3$@ GBです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 모델에는 약 %1$@ GB가 필요합니다 — 당신의 %2$@에는 %3$@ GB의 여유가 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этой модели нужно ~%@ ГБ — на вашем устройстве (%@) свободно %@ ГБ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此模型需要约 %1$@ GB——你的%2$@有 %3$@ GB 可用。"
          }
        }
      }
    },
    "This removes every saved conversation from this %@. It can't be undone.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されたすべての会話がこの%@から削除されます。元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 모든 대화가 이 %@에서 삭제됩니다. 되돌릴 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все сохранённые беседы будут удалены с этого устройства (%@). Это необратимо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从这台%@上删除所有已保存的对话。无法撤销。"
          }
        }
      }
    },
    "To get ready, resolve: ": {
      "localizations": {
        "ja": {
