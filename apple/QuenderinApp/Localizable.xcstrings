        }
      }
    },
    "You can download %@ again any time — it just won't be on this %@.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы сможете снова скачать %@ в любой момент — просто модели не будет на этом устройстве (%@)."
          }
        }
      }
    },
    "You give a goal. The agent plans steps, uses tools on this device, and shows each step in the run log. Mutating actions always ask you first.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы даёте задачу. Агент планирует шаги, использует инструменты на этом устройстве и показывает каждый шаг в журнале. Действия с изменениями всегда сначала спрашивают вас."
          }
        }
      }
    },
    "Your device can run %@ (%@)": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваше устройство может запустить %@ (%@)"
