{
  "sourceLanguage": "en",
  "strings": {
    "%@ is running fully on-device.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ работает полностью на устройстве."
          }
        }
      }
    },
    "%@ · %@ downloads": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · загрузок: %@"
          }
        }
      }
    },
    "%@ · one time, then it's yours offline": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · один раз — и модель ваша, офлайн"
          }
        }
      }
    },
    "%@ — workspace": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ — рабочая папка"
          }
        }
      }
    },
    "%lld": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld"
          }
        }
      }
    },
    "%lld chats selected": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбрано бесед: %lld"
          }
        }
      }
    },
    "%lld models downloading": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загружается моделей: %lld"
          }
        }
      }
    },
    "%lld of %lld installed · %@ on disk · %@ free": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установлено %lld из %lld · %@ на диске · %@ свободно"
          }
        }
      }
    },
    "A one-time download — the main window shows progress and you can cancel any time. Your current model stays installed.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Однократная загрузка — прогресс виден в главном окне, отменить можно в любой момент. Текущая модель останется установленной."
          }
        }
      }
    },
    "A personal AI that lives on your %@ — not in someone's cloud.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Персональный ИИ, который живёт на вашем устройстве (%@) — а не в чужом облаке."
          }
        }
      }
    },
    "About %@": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "О модели %@"
