    "Switch": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключить"
          }
        }
      }
    },
    "Tap to expand → pick a file → Get": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите, чтобы раскрыть → выберите файл → «Скачать»"
          }
        }
      }
    },
    "Tap “All results”, turn off “fits RAM”, or raise max size / download.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите «Все результаты», выключите «влезает в память» или увеличьте лимит размера."
          }
        }
      }
    },
    "Tell the agent what to do on your Mac": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скажите агенту, что сделать на вашем Mac"
          }
        }
      }
