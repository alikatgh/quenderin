<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup/transfer rules. Exclude downloaded GGUF models (filesDir/models, 0.4–9 GB):
     far over the 25 MB cloud-backup cap and freely re-downloadable from the catalog. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="models/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="models/" />
    </device-transfer>
</data-extraction-rules>
