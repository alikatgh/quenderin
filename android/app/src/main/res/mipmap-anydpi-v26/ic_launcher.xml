<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon: the elf artwork (scaled into the safe zone by
     generate_icons.py) over a background sampled from the art's leather frame,
     so the launcher's mask never exposes a foreign color at the edges. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
